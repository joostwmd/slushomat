# Machine server — copy DATABASE_URL, BETTER_AUTH_*, and CORS_* from apps/server/.env
# so API key verification uses the same DB and auth secret as the main API.
#
# Local dev URLs:
#   pnpm dev (portless)     → https://machine.slushomat.localhost:1355/
#   pnpm dev:local          → http://localhost:${PORT:-3004}
#
# To curl the HTTPS URL, you may need -k until the dev TLS cert is trusted, e.g.:
#   MACHINE_SERVER_URL=https://machine.slushomat.localhost:1355 CURL_TLS_INSECURE=1 pnpm -F machine-server test:endpoints

# --- Required (@slushomat/env/server) ---

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/slushomat

# Must match apps/server (min 32 characters)
BETTER_AUTH_SECRET=change-me-use-same-secret-as-apps-server-min-32-chars

# Public base URL of Better Auth (same as main API, e.g. http://localhost:3000)
BETTER_AUTH_URL=http://localhost:3000

# Same as apps/server (used by shared env validation)
CORS_ORIGIN_ADMIN=http://localhost:5173
CORS_ORIGIN_OPERATOR=http://localhost:3003

# --- Optional ---

NODE_ENV=development

# This Hono app listen port
PORT=3004

# CORS for responses from this service only (* is fine in local dev)
CORS_ORIGIN=*
