# Vercel: create a project with Root Directory = apps/server; Install uses repo root via apps/server/vercel.json.
# Set these in Vercel → Settings → Environment Variables (Production + Preview as needed).
# DATABASE_URL: prefer a pooled / serverless-friendly Postgres URL (e.g. Supabase pooler, transaction mode).
# BETTER_AUTH_URL: exact public https origin of this API (same host the browser uses for /api/auth/*).

DATABASE_URL=
BETTER_AUTH_SECRET=
# API origin only (no /api/auth); Better Auth uses default basePath /api/auth
BETTER_AUTH_URL=
CORS_ORIGIN_ADMIN=
CORS_ORIGIN_OPERATOR=

# Supabase (optional — required for admin template product images)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name (Supabase dashboard). Objects: template-products/{productId}/{uuid}.ext
# SUPABASE_STORAGE_BUCKET_TEMPLATE_PRODUCTS=template-products
