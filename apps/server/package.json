{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./trpc/router": "./src/trpc/router.ts",
    "./trpc/init": "./src/trpc/init.ts",
    "./trpc/context": "./src/trpc/context.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "portless api.slushomat tsx watch src/index.ts",
    "dev:local": "tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "generate:auth-schema": "npx auth generate --config ../../packages/auth/src/index.ts --output ../../packages/db/src/schema/index.ts -y",
    "test:endpoints": "bash scripts/test-endpoints.sh",
    "simulate-purchase": "bash scripts/simulate-purchase.sh"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/trpc-server": "^0.4.0",
    "@slushomat/api": "workspace:*",
    "@slushomat/auth": "workspace:*",
    "@slushomat/db": "workspace:*",
    "@slushomat/supabase": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "@slushomat/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "superjson": "^2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@slushomat/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
